# --------------------------------------------------------------------
# Paramètres Django de base
# Les noms recommandés sont préfixés par DJANGO_ (lus par settings/base.py).
# --------------------------------------------------------------------
DJANGO_DEBUG=1
# Générez une clé longue et aléatoire : python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Origines de confiance CSRF en production (ex. https://nettoyage-express.fr)
DJANGO_CSRF_TRUSTED_ORIGINS=
# Niveau de log (DEBUG, INFO, WARNING, ERROR)
DJANGO_LOG_LEVEL=INFO
TIME_ZONE=America/Cayenne
LANGUAGE_CODE=fr-fr
DJANGO_SETTINGS_MODULE=netexpress.settings.dev
# DATABASE_URL laissé vide = SQLite en dev
# DATABASE_URL=postgres://user:password@db:5432/netexpress

# Paramètres SMTP pour l'envoi d'e‑mails (notifications, factures, devis).  Les
# valeurs ci-dessous sont des exemples utilisant Gmail.  Modifiez-les
# selon votre propre fournisseur ou laissez-les vides pour désactiver
# l'envoi d'e‑mails.

# Email backend (ne modifiez pas si vous utilisez SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# Serveur SMTP (ex. smtp.gmail.com)
EMAIL_HOST=smtp.gmail.com
# Port SMTP : 465 pour SSL, 587 pour STARTTLS
EMAIL_PORT=465
# Activation de SSL implicite (True/False).  Si vous utilisez le port 465, laissez à True
EMAIL_USE_SSL=True
# Activation de STARTTLS (True/False).  Si vous utilisez le port 587, mettez True
EMAIL_USE_TLS=False
# Identifiants de connexion (adresse e‑mail et mot de passe d'application)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Expéditeur par défaut (utilisez la même adresse que EMAIL_HOST_USER)
DEFAULT_FROM_EMAIL=
# Destinataire pour le formulaire de contact (laisser vide = DEFAULT_FROM_EMAIL)
CONTACT_RECEIVER_EMAIL=
# Destinataire pour les notifications de tâches (laisser vide = DEFAULT_FROM_EMAIL)
TASK_NOTIFICATION_EMAIL=

# --------------------------------------------------------------------
# Copies des e-mails de NOTIFICATION ADMINISTRATIVE (ex. formulaire de contact)
# Ne s'applique pas aux e-mails envoyés aux clients.
# --------------------------------------------------------------------
# Copies fixes, séparées par des virgules (laisser vide si aucune).
NOTIFICATION_CC=
NOTIFICATION_BCC=
# Adresse mise en copie (CC + CCI) pendant la période de garantie.
# Laisser VIDE désactive la copie.  Renseignez votre adresse pour l'activer,
# par exemple : REVIEW_COPY_EMAIL=prenom.nom@exemple.fr
REVIEW_COPY_EMAIL=
# Date de fin de la copie de garantie (AAAA-MM-JJ) = livraison + 30 jours.
REVIEW_COPY_UNTIL=2026-07-22

# URL publique du site (liens dans les e-mails)
SITE_URL=http://localhost:8000