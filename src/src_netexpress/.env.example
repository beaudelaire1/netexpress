# ============================================================
# Configuration exemple pour NetExpress
# ============================================================
# 
# ⚠️  ATTENTION - SÉCURITÉ DES CLÉS API
# ============================================================
# 
# NE JAMAIS commiter de fichier .env contenant des clés réelles !
# Brevo détecte automatiquement les clés exposées sur GitHub
# et les RÉVOQUE immédiatement pour des raisons de sécurité.
#
# POUR LE DÉVELOPPEMENT LOCAL:
#   1. Copiez ce fichier vers .env.local (déjà dans .gitignore)
#   2. Remplissez avec vos vraies valeurs
#   3. Ne commitez JAMAIS .env.local
#
# POUR LA PRODUCTION (Render.com):
#   Les secrets doivent être configurés dans le Dashboard Render:
#   Environment > Environment Variables
#   - DJANGO_SECRET_KEY
#   - DATABASE_URL
#   - BREVO_API_KEY  ← Générez une NOUVELLE clé dans Brevo !
#
# ============================================================

# Mode debug (False en production)
DEBUG=False

# Clé secrète Django (générez une nouvelle clé pour la production)
DJANGO_SECRET_KEY=your-secret-key-here

# Domaines autorisés (séparés par des virgules)
ALLOWED_HOSTS=www.nettoyageexpresse.fr,nettoyageexpresse.fr,netexpress.onrender.com,.onrender.com

# Localisation
TIME_ZONE=America/Martinique
LANGUAGE_CODE=fr-fr

# Configuration Django
DJANGO_SETTINGS_MODULE=netexpress.settings.prod

# Base de données (PostgreSQL en production, laissez vide pour SQLite en dev)
DATABASE_URL=postgresql://user:password@host:port/database

# ============================================================
# Configuration Email Brevo
# ============================================================
# 
# Option 1: API Transactionnelle (recommandée)
#   BREVO_EMAIL_MODE=api
#   BREVO_API_KEY=xkeysib-xxxx...
#
# Option 2: SMTP Brevo
#   BREVO_EMAIL_MODE=smtp
#   BREVO_SMTP_LOGIN=xxx@smtp-brevo.com
#   BREVO_SMTP_PASSWORD=xsmtpsib-xxxx...
#
# ============================================================

EMAIL_BACKEND=core.backends.brevo_backend.BrevoEmailBackend
BREVO_EMAIL_MODE=api
BREVO_API_KEY=your-brevo-api-key-here

# Pour le mode SMTP (alternatif):
# BREVO_SMTP_LOGIN=your-smtp-login@smtp-brevo.com
# BREVO_SMTP_PASSWORD=your-smtp-password-here

# Configuration expéditeur (doit être validé dans Brevo)
DEFAULT_FROM_EMAIL=contact@nettoyageexpresse.fr
DEFAULT_FROM_NAME=Nettoyage Express

# Emails de notification
CONTACT_RECEIVER_EMAIL=n.express@nettoyageexpresse.fr
CONTACT_CC_EMAIL=vilmebeaudelaire5@gmail.com
TASK_NOTIFICATION_EMAIL=n.express@nettoyageexpresse.fr

# information bancaire pour les devis
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_NAME=Nettoyage Express 

# information sur l'entreprise pour les devis (affichées sur factures/devis PDF)
# ⚠️ SIRET / TVA / IBAN / BIC sont obligatoires et NE DOIVENT PAS rester vides en production.
COMPANY_NAME=Nettoyage Express
COMPANY_TAGLINE=Espaces verts, nettoyage, peinture, bricolage
COMPANY_ADDRESS_LINE1=753, Chemin de la Désirée
COMPANY_ADDRESS_LINE2=97351 Matoury
COMPANY_ADDRESS=753 Chemin la Désirée, 97351 Matoury
COMPANY_SIRET=820 474 195 00022
COMPANY_TVA=
COMPANY_BIC=
COMPANY_PHONE=05 94 30 23 68 / 06 94 46 20 12
COMPANY_NUMBER_PHONE=0594302368 / 0694462012
COMPANY_EMAIL=contact@nettoyageexpresse.fr
COMPANY_WEBSITE=www.nettoyageexpresse.fr
COMPANY_APE=8130Z